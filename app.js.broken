      "涓€鏍烽珮锛屽氨鏄湅瀹冨乏鍙冲悓涓€鏉℃í绾夸笂鐨勪綅缃€?,
      "鎵惧埌鍜屽畠鍚岄珮鐨勯偅涓€涓骇浣嶃€?
    ],
    solutionSteps: [
      stepText(`鍏堟壘鍒?{animal}鐨勪綅缃€俙, { slotIndex }),
      stepText("鍜屽畠涓€鏍烽珮鐨勪綅缃湪鍙︿竴杈瑰悓涓€鏉℃í绾夸笂銆?, { slotIndex: targetSlot }),
      stepText(`鍧愬湪閭ｉ噷鐨勬槸${answer}锛屾墍浠ョ瓟妗堟槸${answer}銆俙, { slotIndex: targetSlot, answer })
    ]
  };
}

function createTopQuestion(steps) {
  const scene = applyRotationSteps(BASE_WHEEL, steps);
  const answer = scene[0];
  const prompt = steps
    ? `鎽╁ぉ杞『鏃堕拡杞?${steps} 鏍煎悗锛屾渶涓婇潰鏄皝锛焋
    : "鐜板湪璋佸潗鍦ㄦ渶涓婇潰锛?;
  return {
    title: "鐪嬫渶涓婇潰鐨勫骇浣?,
    prompt,
    mode: steps ? "rotate" : "observe",
    targetSteps: steps,
    choices: buildChoiceSet(answer, BASE_WHEEL),
    answer,
    hints: [
      "鏈€涓婇潰鍙湁涓€涓綅缃€?,
      steps ? `鍏堢畻娓呮椤烘椂閽堣浆浜?${steps} 鏍笺€俙 : "鍏堢湅鏈€椤朵笂鐨勫骇浣嶃€?,
      "鏈€鍚庡啀鐪嬫渶涓婇潰鐨勫姩鐗╂槸璋併€?
    ],
    solutionSteps: [
      stepText("鍏堝叧娉ㄦ渶涓婇潰鐨勫骇浣嶃€?, { slotIndex: 0 }),
      steps
        ? stepText(`鎽╁ぉ杞『鏃堕拡杞?${steps} 鏍煎悗锛屽啀鐪嬫渶涓婇潰銆俙, { slotIndex: 0, sceneSteps: steps })
        : stepText("鐜板湪杩樻病鏈夎浆鍔紝鐩存帴鐪嬫渶涓婇潰銆?, { slotIndex: 0 }),
      stepText(`鏈€涓婇潰鏄?{answer}锛屾墍浠ョ瓟妗堟槸${answer}銆俙, { slotIndex: 0, answer, sceneSteps: steps || undefined })
    ]
  };
}

function createCounterclockwiseQuestion(animal) {
  const startSlot = animalSlot(animal);
  const targetSlot = (startSlot + 7) % WHEEL_SLOT_COUNT;
  const answer = BASE_WHEEL[targetSlot];
  return {
    title: "閫嗘椂閽堝墠涓€鏍?,
    prompt: `鐜板湪${animal}鐨勯€嗘椂閽堜竴鏍兼槸璋侊紵`,
    mode: "observe",
