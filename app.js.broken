      stepText("閫嗘椂閽堝氨鏄線鍥為€€涓€鏍笺€?, { slotIndex: targetSlot }),
      stepText(`閭ｄ釜浣嶇疆鏄?{answer}锛屾墍浠ョ瓟妗堟槸${answer}銆俙, { slotIndex: targetSlot, answer })
    ]
  };
}

function createRotateSameHeightQuestion(mover, targetOwner, watchAnimal) {
  const steps = rotationStepsForAnimalToSlot(mover, animalSlot(targetOwner));
  const rotated = applyRotationSteps(BASE_WHEEL, steps);
  const answer = computeSameHeightAnimal(rotated, watchAnimal);
  return {
    title: "杞埌鎸囧畾浣嶇疆鍚庢壘鍚岄珮",
    prompt: `濡傛灉${mover}杞埌${targetOwner}鐨勪綅缃笂锛岄偅涔堣皝涓?{watchAnimal}涓€鏍烽珮锛焋,
    mode: "rotate",
    targetSteps: steps,
    choices: buildChoiceSet(answer, BASE_WHEEL),
    answer,
    hints: [
      `鍏堢湅${mover}瑕佽浆鍑犳牸鎵嶈兘鍒?{targetOwner}鍘熸潵鐨勪綅缃€俙,
      "鍏ㄩ儴灏忓姩鐗╀細涓€璧烽『鏃堕拡杞浉鍚岀殑鏍兼暟銆?,
      `杞畬浠ュ悗锛屽啀鍘绘壘鍜?{watchAnimal}涓€鏍烽珮鐨勪綅缃€俙
    ],
    solutionSteps: buildRotateSameHeightSteps(mover, targetOwner, watchAnimal, answer)
  };
}

