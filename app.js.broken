function flattenQuestionTypes(types) {
  let globalIndex = 0;
  return types.flatMap((type) => {
    const zone = ZONES.find((item) => item.id === type.zoneId);
    return type.questions.map((question, questionIndex) => {
      const level = {
        ...question,
        id: `${type.id}-Q${questionIndex + 1}`,
        typeId: type.id,
        typeTitle: type.title,
        typeSummary: type.summary,
        typeNumber: type.typeNumber,
        questionNumber: questionIndex + 1,
        zoneName: zone.name,
        number: globalIndex + 1,
        index: globalIndex
      };
      globalIndex += 1;
      return level;
    });
  });
}

function createObserveNextQuestion(animal) {
  const startSlot = animalSlot(animal);
  const targetSlot = (startSlot + 1) % WHEEL_SLOT_COUNT;
  const answer = BASE_WHEEL[targetSlot];
  return {
    title: "椤烘椂閽堜笅涓€鏍?,
    prompt: `鐜板湪璋佸潗鍦?{animal}鐨勯『鏃堕拡涓嬩竴鏍硷紵`,
    mode: "observe",
    choices: buildChoiceSet(answer, BASE_WHEEL),
    answer,
    hints: [
      `鍏堟壘鍒?{animal}鐜板湪鍧愮殑浣嶇疆銆俙,
      "椤烘椂閽堝氨鏄窡鐫€绠ご鏂瑰悜寰€鍓嶈蛋銆?,
      "鍙湅鍓嶉潰涓€鏍硷紝涓嶈澶氳蛋銆?
    ],
    solutionSteps: [
      stepText(`鍏堟壘鍒?{animal}鐨勪綅缃€俙, { slotIndex: startSlot }),
      stepText("椤虹潃绠ご寰€鍓嶇湅涓€鏍笺€?, { slotIndex: targetSlot }),
      stepText(`閭ｄ釜浣嶇疆鏄?{answer}锛屾墍浠ョ瓟妗堟槸${answer}銆俙, { slotIndex: targetSlot, answer })
    ]
  };
}

function createSameHeightQuestion(animal) {
  const slotIndex = animalSlot(animal);
  const targetSlot = SAME_HEIGHT_SLOT[slotIndex];
  const answer = BASE_WHEEL[targetSlot];
  return {
    title: "璋佸拰璋佷竴鏍烽珮",
    prompt: `鐜板湪璋佸拰${animal}涓€鏍烽珮锛焋,
    mode: "observe",
    choices: buildChoiceSet(answer, BASE_WHEEL),
    answer,
